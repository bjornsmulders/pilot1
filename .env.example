# Kopieer naar .env.local en vul in. Zie docs/pilot-setup.md voor de volledige uitleg.
# Nooit committen met echte waarden.

# --- Supabase (verplicht vanaf slice 1) ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alleen server-side gebruikt (src/lib/supabase/admin.ts). NOOIT in clientcode of
# NEXT_PUBLIC_-variabelen zetten.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactionele e-mail) --------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="JourneyOS <noreply@jouwdomein.nl>"

# --- Mollie (betalingen, vanaf de betalingen-slice) ----------------------------
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=

# --- PostHog (product analytics) -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry (foutmonitoring) ----------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Applicatie ------------------------------------------------------------------
# Basis-URL van de app, gebruikt om onboarding-/uitnodigingslinks op te bouwen.
NEXT_PUBLIC_APP_URL=http://localhost:3000
